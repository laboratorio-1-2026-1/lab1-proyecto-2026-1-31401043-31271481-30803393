# ==============================================================================
# SmartGym API - Archivo de Configuración de Ejemplo (.env.example)
# ==============================================================================
# Para configurar tu entorno local, sigue estos pasos:
# 1. Renombralo exactamente como '.env' en la raíz del proyecto.
# 2. Modifica los valores a continuación para que coincidan con tu configuración local.
#

# ------------------------------------------------------------------------------
# Configuración de la Base de Datos (PostgreSQL)
# ------------------------------------------------------------------------------
# Formato: postgresql://[usuario]:[contraseña]@[servidor]:[puerto]/[nombre_base_de_datos]
#
# - Reemplaza 'postgres' si tu usuario es diferente.
# - Reemplaza 'tu_contraseña' por la contraseña que definiste al instalar PostgreSQL.
# - Asegúrate de haber creado primero la base de datos llamada 'gym' en PostgreSQL.
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost/gym

# ------------------------------------------------------------------------------
# Configuración de Seguridad y JWT
# ------------------------------------------------------------------------------
# SECRET_KEY: Clave para firmar y validar tokens de acceso JWT.
# ¡Es sumamente importante usar una clave robusta en producción!
SECRET_KEY="tu_clave_secreta_super_segura_de_ejemplo_para_pruebas_locales"

# Tiempo de expiración para los tokens de acceso en minutos.
# Por defecto se establece en 30 minutos.
ACCESS_TOKEN_EXPIRE_MINUTES=30
