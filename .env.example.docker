# ==============================================================================
# SmartGym API - Archivo de Configuración para Docker (.env.example.docker)
# ==============================================================================
#
# INSTRUCCIONES PARA CONFIGURAR EL ENTORNO CON DOCKER:
# -------------------------------------------------------
# 1. Copia este archivo y renómbralo exactamente como '.env' en la raíz del proyecto:
#       cp .env.example.docker .env
#
# 2. Modifica los valores marcados con <CAMBIAR> según tu configuración deseada.
#
# 3. IMPORTANTE: Cuando uses Docker Compose, el host de la base de datos NO es
#    'localhost'. Debes usar el nombre del servicio definido en docker-compose.yml,
#    que por defecto es 'db'.
#
# 4. Los valores de POSTGRES_USER, POSTGRES_PASSWORD y POSTGRES_DB deben coincidir
#    exactamente con los definidos en el servicio 'db' de docker-compose.yml.
#
# 5. NO subas el archivo '.env' al repositorio. Ya está excluido por .gitignore.
# ==============================================================================


# ------------------------------------------------------------------------------
# Configuración de la Base de Datos (PostgreSQL en Docker)
# ------------------------------------------------------------------------------
# ⚠️  DIFERENCIA CLAVE vs entorno local:
#     El host debe ser el nombre del servicio Docker: 'db'
#     NO uses 'localhost' cuando corres con docker-compose.
#
# Formato: postgresql+asyncpg://[usuario]:[contraseña]@[servicio_docker]:[puerto]/[nombre_bd]
#
# - POSTGRES_USER  → mismo valor que en docker-compose.yml (variable POSTGRES_USER del servicio db)
# - POSTGRES_PASSWORD → mismo valor que en docker-compose.yml (variable POSTGRES_PASSWORD del servicio db)
# - POSTGRES_DB    → mismo valor que en docker-compose.yml (variable POSTGRES_DB del servicio db)
#
DATABASE_URL=postgresql+asyncpg://postgres:<CAMBIAR_CONTRASEÑA>@db:5432/gym

# Credenciales del contenedor PostgreSQL (deben coincidir con docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CAMBIAR_CONTRASEÑA>
POSTGRES_DB=gym


# ------------------------------------------------------------------------------
# Configuración de Seguridad y JWT
# ------------------------------------------------------------------------------
# SECRET_KEY: Clave para firmar y validar tokens de acceso JWT.
# ¡Usa una clave larga y aleatoria en producción!
#
# Puedes generar una clave segura con el siguiente comando en tu terminal:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
SECRET_KEY=<CAMBIAR_POR_UNA_CLAVE_SECRETA_SEGURA>

# Tiempo de expiración para los tokens de acceso en minutos (por defecto: 30).
ACCESS_TOKEN_EXPIRE_MINUTES=30